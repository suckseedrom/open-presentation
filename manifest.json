{
  "name": "open-presentation",
  "version": "1.11.0",
  "distribution": "public-skill-repo",
  "package_type": "plugin-skill-pack",
  "primary_install_unit": "plugin",
  "entrypoint": "SKILL.md",
  "plugin_entrypoint": "manifest.json",
  "plugin_marketplace_root": ".agents/plugins/marketplace.json",
  "plugin_bundle_root": "plugins/open-presentation/",
  "reference_root": "reference/",
  "example_root": "examples/",
  "template_root": "templates/",
  "install_modes": [
    "agent-plugin",
    "markdown-skill",
    "repo-copy"
  ],
  "preferred_install_mode": "agent-plugin",
  "public_install_surface": "github-marketplace",
  "install_commands": {
    "codex-plugin-marketplace": "codex plugin marketplace add suckseedrom/open-presentation",
    "codex-plugin-install": "codex plugin add open-presentation@open-presentation",
    "claude-plugin-marketplace": "/plugin marketplace add suckseedrom/open-presentation",
    "markdown-skill": "npx skills add suckseedrom/open-presentation",
    "repo-copy": "git clone https://github.com/suckseedrom/open-presentation.git"
  },
  "plugin_contract": {
    "wrapper": "thin",
    "workflow_authority": "SKILL.md",
    "repo_marketplace_file": ".agents/plugins/marketplace.json",
    "repo_plugin_bundle": "plugins/open-presentation/",
    "requires_mcp": false,
    "requires_private_paths": false,
    "requires_hidden_runtime": false
  },
  "supported_clients": [
    "codex",
    "claude-code",
    "claude-desktop",
    "opencode",
    "cursor",
    "markdown-skill-runners",
    "plugin-capable-agent-apps"
  ],
  "authoritative_files": [
    "SKILL.md",
    "docs/PLUGIN-NATIVE-V2.md",
    "reference/PRODUCT_PILLARS.md",
    "reference/STYLE_INDEX.md",
    "reference/STYLE_GUIDE.md",
    "reference/RECHECK.md",
    "reference/scene-grammar.json",
    "templates/index.json",
    "docs/OUTPUT-CONTRACT.md",
    "lib/player.js",
    "lib/player.css",
    "lib/editor-model.js",
    "lib/editor-renderer.js",
    "lib/editor-export.js",
    "lib/README.md"
  ],
  "capabilities": {
    "playback": "zero-dependency local HTML",
    "composition": "versioned portable JSON with validated import and autosave",
    "video_export": "deterministic browser 4K WebM export directly in player",
    "plugin_native_v2": "typed orchestrator, session contract, and host adapter scaffold"
  },
  "notes": "Skill-first public repo with plugin install support for Claude and Codex, optimized for public GitHub marketplace installation, with a thin plugin wrapper, zero-dependency HTML playback, adaptive input-derived scene planning, contextual product mockups and input-led language, varied scene lifecycles, closed per-scene dual-aspect QA, direct player-integrated deterministic 4K WebM export, and advanced plugin-native v2 scaffolding for future app-surface binding."
}
