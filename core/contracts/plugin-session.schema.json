{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/suckseedrom/open-presentation/core/contracts/plugin-session.schema.json",
  "title": "OpenPresentationPluginSession",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionId",
    "status",
    "host",
    "inputs",
    "plan",
    "panels",
    "actions"
  ],
  "properties": {
    "sessionId": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "planning", "preview-ready", "export-ready", "error"]
    },
    "host": {
      "type": "string",
      "enum": ["codex", "claude-code", "unknown"]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["briefText"],
      "properties": {
        "briefText": { "type": "string", "minLength": 1 },
        "requestedTemplate": { "type": "string" },
        "requestedOutputMode": {
          "type": "string",
          "enum": ["html", "html-player", "4k-video"]
        }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectTitle", "templateShortlist", "sceneCount"],
      "properties": {
        "projectTitle": { "type": "string", "minLength": 1 },
        "templateShortlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sceneCount": { "type": "integer", "minimum": 1 }
      }
    },
    "panels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "title"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["brief", "template", "scene-plan", "preview", "export", "qa"]
          },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["generate", "revise", "preview", "export", "write-workspace"]
          }
        }
      }
    }
  }
}
